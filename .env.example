# --- App ---
APP_NAME=Post Scheduler API
APP_ENV=development
FRONTEND_URL=http://localhost:4321
CORS_ORIGINS_STR=http://localhost:4321

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/post_scheduler
SQL_ECHO=false

# --- JWT (HS256) ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# --- Google OAuth ---
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Token Encryption (Fernet) ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- X (Twitter) OAuth 2.0 PKCE ---
# https://developer.twitter.com/en/portal/dashboard
# Required scopes: tweet.read tweet.write users.read offline.access
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/accounts/x/callback

Consumer = Y7MJqv4DTwtDHpQDGCtVOj7xj
Secret = n7ZG4vsMuuSnMbJyXbmQjWOTABxYQS5ZdhW1kZsM2iYPUqKS8G
Bearer = AAAAAAAAAAAAAAAAAAAAALYU8QEAAAAAwSuLMy%2BLbQCOMiJfWj7yewnujKU%3DeXolIDmzYdVCvZD39nMUVZd5qwJ2rWLA2Mo1ks21AXh6aWfC0i
# --- Redis ---
REDIS_URL=redis://localhost:6379/0
